{
  "name": "ifinanca",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "cloudflare:dev": "npm run build && wrangler pages dev dist",
    "cloudflare:deploy": "npm run build && wrangler pages deploy dist --project-name ifinanca",
    "firebase:emulators": "firebase emulators:start",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "firebase": "^12.15.0",
    "pluggy-connect-sdk": "^2.13.0",
    "pluggy-js": "^0.19.3",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "daisyui": "^5.6.6",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.106.0"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
